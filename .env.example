# Azure OpenAI Configuration (for Microsoft Agent Framework)
# Uses DefaultAzureCredential - no API key needed if logged in via 'az login'
AZURE_OPENAI_ENDPOINT=https://eastus2.api.cognitive.microsoft.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# GitHub Copilot (alternative backend)
# Requires: gh auth login && gh extension install github/gh-copilot
GITHUB_COPILOT_MODEL=gpt-4o

# LangGraph/OpenAI (for bonus comparison)
# OPENAI_API_KEY=sk-...
